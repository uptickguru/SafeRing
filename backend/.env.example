# SafeRing Backend — Environment Configuration
# Copy to .env and adjust for your environment.

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_TIMEOUT=30s

# Database
DATABASE_URL=safering.db
# For Postgres (production):
# DATABASE_URL=postgres://user:password@localhost:5432/safering?sslmode=require

# Scraper Settings
SCRAPER_INTERVAL=6h
SCRAPER_FTC_ENABLED=true
# FTC API key (from api.data.gov/signup). Use DEMO_KEY for limited testing.
SCRAPER_FTC_API_KEY=DEMO_KEY
SCRAPER_BBB_ENABLED=true
SCRAPER_REDDIT_ENABLED=true
SCRAPER_REDDIT_CLIENT_ID=
SCRAPER_REDDIT_CLIENT_SECRET=
SCRAPER_REDDIT_USER_AGENT=SafeRing/1.0

# SOCKS5 proxy for sources that rate-limit by IP (Reddit, some gov sites)
# Set to your Tor proxy ('127.0.0.1:9050'), a commercial proxy service, or leave blank for direct connections.
SOCKS5_PROXY=

# Rate Limiting
RATE_LIMIT_PER_IP=100
RATE_LIMIT_WINDOW=1m

# Logging
LOG_LEVEL=info
LOG_FORMAT=console

# ML Pipeline
ML_MODEL_DIR=./data/models
ML_TRAIN_INTERVAL=24h

# Redis (optional, for distributed rate limiting)
# REDIS_URL=redis://localhost:6379/0
